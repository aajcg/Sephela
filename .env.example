# ==============================================================================
# Sephela - Local Development
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
SEPHELA_ENV=local
SEPHELA_DEBUG=true
SEPHELA_PROJECT_NAME=Sephela
SEPHELA_API_V1_PREFIX=/api/v1

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
SEPHELA_POSTGRES_HOST=localhost
SEPHELA_POSTGRES_PORT=5432
SEPHELA_POSTGRES_USER=sephela
SEPHELA_POSTGRES_PASSWORD=sephela
SEPHELA_POSTGRES_DB=sephela

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
SEPHELA_REDIS_HOST=localhost
SEPHELA_REDIS_PORT=6379
SEPHELA_REDIS_DB=0

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------
SEPHELA_STORAGE_BACKEND=local
SEPHELA_STORAGE_LOCAL_ROOT=./data/storage

# Uncomment when MinIO is ready
# SEPHELA_STORAGE_BACKEND=s3
# SEPHELA_S3_ENDPOINT_URL=http://localhost:9000
# SEPHELA_S3_BUCKET=sephela-samples
# SEPHELA_S3_ACCESS_KEY=
# SEPHELA_S3_SECRET_KEY=
# SEPHELA_S3_REGION=us-east-1

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
SEPHELA_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_32_PLUS_CHAR_SECRET
SEPHELA_ALGORITHM=HS256
SEPHELA_ACCESS_TOKEN_EXPIRE_MINUTES=30
SEPHELA_CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=

# Optional
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LOCAL_LLM_BASE_URL=

# ------------------------------------------------------------------------------
# Agent Models
# ------------------------------------------------------------------------------
MANIFEST_MODEL=deepseek/deepseek-chat
PERMISSION_MODEL=deepseek/deepseek-chat
CODE_MODEL=deepseek/deepseek-chat
API_MODEL=deepseek/deepseek-chat
NETWORK_MODEL=deepseek/deepseek-chat
THREAT_INTEL_MODEL=deepseek/deepseek-chat
RISK_MODEL=deepseek/deepseek-chat
REPORT_MODEL=deepseek/deepseek-chat

# ------------------------------------------------------------------------------
# LLM Runtime
# ------------------------------------------------------------------------------
LLM_PROVIDER=openrouter
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120

# ------------------------------------------------------------------------------
# LangGraph / Agents
# ------------------------------------------------------------------------------
AGENT_ENABLE_PARALLEL=true
AGENT_MAX_CONCURRENCY=8

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
SEPHELA_LOG_LEVEL=INFO
SEPHELA_LOG_JSON=false

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1